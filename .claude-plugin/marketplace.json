{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "boost-your-ai",
  "version": "0.0.1",
  "description": "Custom skills for boosting AI-assisted development workflows",
  "owner": {
    "name": "Arnaud Héritier",
    "url": "https://github.com/aheritier"
  },
  "plugins": [
    {
      "name": "jj-lsp",
      "description": "Java language server (jj-language-server) for lightweight code intelligence - no JVM required",
      "version": "0.1.0",
      "source": "./plugins/jj-lsp",
      "category": "development",
      "homepage": "https://github.com/aheritier/boost-your-ai/tree/main/plugins/jj-lsp",
      "strict": false,
      "lspServers": {
        "jj-language-server": {
          "command": "jj-language-server",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".java": "java"
          },
          "startupTimeout": 10000
        }
      }
    }
  ]
}
